# Copy to .env and `source .env` (or `set -a; . ./.env; set +a`) before rendering.
# .env is gitignored — never commit real keys.

# ---- Voiceover provider: elevenlabs | azure | none ----
export TTS_PROVIDER=none

# --- ElevenLabs (most natural English VO) ---
# export TTS_PROVIDER=elevenlabs
# export ELEVENLABS_API_KEY=sk_...
# export ELEVENLABS_VOICE_ID=...            # pick a calm narration voice
# export ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Azure Neural TTS ---
# export TTS_PROVIDER=azure
# export AZURE_SPEECH_KEY=...
# export AZURE_SPEECH_REGION=eastus
# export AZURE_VOICE=en-US-AndrewMultilingualNeural

# ---- Optional: font for on-screen captions ----
# export FONT=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
